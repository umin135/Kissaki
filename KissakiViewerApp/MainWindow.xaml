<Window x:Class="KissakiViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:adonisUI="clr-namespace:AdonisUI;assembly=AdonisUI"
        xmlns:conv="clr-namespace:KissakiViewer.Converters"
        Title="{Binding WindowTitle}"
        Icon="Assets/app.ico"
        Width="1280" Height="800"
        MinWidth="900" MinHeight="500"
        Style="{DynamicResource {x:Type Window}}"
        Loaded="Window_Loaded">

    <Window.Resources>
        <BooleanToVisibilityConverter           x:Key="BoolToVis"/>
        <conv:InvertBoolConverter               x:Key="InvertBool"/>
        <conv:InvertBoolToVisibilityConverter   x:Key="InvertBoolToVis"/>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>       <!-- 0: Menu bar -->
            <RowDefinition Height="*"/>          <!-- 1: Main content -->
            <RowDefinition Height="5" x:Name="ConsoleSplitterRow" MinHeight="0"/>  <!-- 2: Splitter -->
            <RowDefinition Height="160" x:Name="ConsoleRow" MinHeight="26"/>       <!-- 3: Console -->
            <RowDefinition Height="Auto"/>       <!-- 4: Status bar -->
        </Grid.RowDefinitions>

        <!-- Menu bar -->
        <Border Grid.Row="0"
                Height="30"
                Background="{DynamicResource {x:Static adonisUI:Brushes.Layer1BackgroundBrush}}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource {x:Static adonisUI:Brushes.Layer1BorderBrush}}">
            <Menu HorizontalAlignment="Left"
                  VerticalAlignment="Center"
                  Background="Transparent"
                  BorderThickness="0"
                  Padding="2,0">
                <Menu.ItemContainerStyle>
                    <Style TargetType="MenuItem">
                        <Setter Property="Padding" Value="12,5"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Foreground" Value="{DynamicResource {x:Static adonisUI:Brushes.ForegroundBrush}}"/>
                    </Style>
                </Menu.ItemContainerStyle>
                <MenuItem Header="View"/>
                <MenuItem Header="Settings" Click="Settings_Click"/>
                <MenuItem Header="Help" Click="Help_Click"/>
            </Menu>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="140"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: folder tree -->
            <Grid Grid.Column="0"
                  Background="{DynamicResource {x:Static adonisUI:Brushes.Layer1BackgroundBrush}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="8,5"
                        BorderThickness="0,0,0,1"
                        BorderBrush="{DynamicResource {x:Static adonisUI:Brushes.Layer1BorderBrush}}">
                    <TextBlock Text="Directory"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource {x:Static adonisUI:Brushes.DisabledForegroundBrush}}"/>
                </Border>

                <TreeView Grid.Row="1"
                          x:Name="FolderTreeView"
                          ItemsSource="{Binding FolderTree}"
                          BorderThickness="0"
                          Background="Transparent"
                          SelectedItemChanged="FolderTreeView_SelectedItemChanged">
                    <TreeView.Resources>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="True"/>
                            <Setter Property="Padding" Value="2,3"/>
                            <Setter Property="Foreground" Value="#DCDCDC"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#c0392b"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1F1F1F"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TreeView.Resources>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding DisplayName}" FontSize="12" Padding="2,1"/>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Grid>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="{DynamicResource {x:Static adonisUI:Brushes.Layer1BorderBrush}}"/>

            <!-- Right: file browser -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Browser toolbar -->
                <Border Grid.Row="0"
                        Background="{DynamicResource {x:Static adonisUI:Brushes.Layer1BackgroundBrush}}"
                        BorderThickness="0,0,0,1"
                        BorderBrush="{DynamicResource {x:Static adonisUI:Brushes.Layer1BorderBrush}}"
                        Padding="8,5">
                    <DockPanel LastChildFill="False">
                        <TextBox DockPanel.Dock="Left"
                                 Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                                 MinWidth="200" MaxWidth="320"
                                 VerticalAlignment="Center"
                                 Tag="Search by name..."/>

                        <ComboBox DockPanel.Dock="Left"
                                  ItemsSource="{Binding TypeFilters}"
                                  SelectedItem="{Binding SelectedTypeFilter}"
                                  Width="90" Margin="6,0"/>

                        <!-- TODO: Grid view layout broken (all items in one row) — re-enable after fix -->
                        <ToggleButton DockPanel.Dock="Right"
                                      IsChecked="{Binding IsGridView}"
                                      ToolTip="Grid View"
                                      Padding="6,3"
                                      Visibility="Collapsed">
                            <TextBlock Text="⊞" FontSize="13"/>
                        </ToggleButton>
                        <ToggleButton DockPanel.Dock="Right"
                                      IsChecked="{Binding IsGridView, Converter={StaticResource InvertBool}, Mode=OneWay}"
                                      ToolTip="List View"
                                      Padding="6,3" Margin="0,0,2,0">
                            <TextBlock Text="≡" FontSize="14"/>
                        </ToggleButton>
                    </DockPanel>
                </Border>

                <!-- Asset area -->
                <Grid Grid.Row="1">

                    <!-- List view -->
                    <ListView x:Name="AssetListView"
                              ItemsSource="{Binding FilteredAssets}"
                              SelectedItem="{Binding SelectedAsset}"
                              BorderThickness="0"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              MouseDoubleClick="AssetList_MouseDoubleClick"
                              GridViewColumnHeader.Click="AssetListView_ColumnHeaderClick"
                              Visibility="{Binding IsGridView, Converter={StaticResource InvertBoolToVis}}">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="6,3"/>
                                <Setter Property="MinHeight" Value="26"/>
                                <Setter Property="Foreground" Value="#DCDCDC"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <!-- Replace AdonisUI template to remove gradient highlight -->
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    Padding="{TemplateBinding Padding}"
                                                    MinHeight="{TemplateBinding MinHeight}"
                                                    SnapsToDevicePixels="True">
                                                <GridViewRowPresenter
                                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <!-- Tag = MainViewModel proxy so ContextMenu can reach commands -->
                                <Setter Property="Tag"
                                        Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListView}}"/>
                                <Setter Property="ContextMenu">
                                    <Setter.Value>
                                        <ContextMenu>
                                            <!-- PlacementTarget = ListViewItem; .Tag = MainViewModel; .DataContext = AssetItemViewModel -->
                                            <!-- G1M-only items -->
                                            <MenuItem Header="Raw Export (.g1m)"
                                                      Command="{Binding PlacementTarget.Tag.ExportSelectedCommand,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Visibility="{Binding PlacementTarget.DataContext.IsG1m,
                                                                   RelativeSource={RelativeSource AncestorType=ContextMenu},
                                                                   Converter={StaticResource BoolToVis}}"/>
                                            <MenuItem Header="Raw Export (Bundle)"
                                                      Command="{Binding PlacementTarget.Tag.ExportBundleCommand,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Visibility="{Binding PlacementTarget.DataContext.IsG1m,
                                                                   RelativeSource={RelativeSource AncestorType=ContextMenu},
                                                                   Converter={StaticResource BoolToVis}}"/>
                                            <!-- Non-G1M item -->
                                            <MenuItem Header="Raw Export"
                                                      Command="{Binding PlacementTarget.Tag.ExportSelectedCommand,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Visibility="{Binding PlacementTarget.DataContext.IsG1m,
                                                                   RelativeSource={RelativeSource AncestorType=ContextMenu},
                                                                   Converter={StaticResource InvertBoolToVis}}"/>
                                        </ContextMenu>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1F1F1F"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#c0392b"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Name" Width="300">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontFamily="Consolas" FontSize="12"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Hash" Width="110">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding KtidHex}"
                                                       FontFamily="Consolas" FontSize="11" Opacity="0.5"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Type" Width="60">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding TypeExt}" FontSize="11" Opacity="0.65"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Container" Width="170">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Container}"
                                                       FontFamily="Consolas" FontSize="11" Opacity="0.45"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Size" Width="80">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding SizeStr}" FontSize="11" Opacity="0.55"
                                                       HorizontalAlignment="Right"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <!-- Grid view -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Visibility="{Binding IsGridView, Converter={StaticResource BoolToVis}}">
                        <ListBox ItemsSource="{Binding FilteredAssets}"
                                 SelectedItem="{Binding SelectedAsset}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                 MouseDoubleClick="AssetList_MouseDoubleClick">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" Margin="4"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="3"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <!-- Replace AdonisUI template to remove gradient highlight -->
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Bd"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        Padding="{TemplateBinding Padding}"
                                                        SnapsToDevicePixels="True">
                                                    <ContentPresenter
                                                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Tag"
                                            Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                                    <Setter Property="ContextMenu">
                                        <Setter.Value>
                                            <ContextMenu>
                                                <!-- G1M-only items -->
                                                <MenuItem Header="Raw Export (.g1m)"
                                                          Command="{Binding PlacementTarget.Tag.ExportSelectedCommand,
                                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          Visibility="{Binding PlacementTarget.DataContext.IsG1m,
                                                                       RelativeSource={RelativeSource AncestorType=ContextMenu},
                                                                       Converter={StaticResource BoolToVis}}"/>
                                                <MenuItem Header="Raw Export (Bundle)"
                                                          Command="{Binding PlacementTarget.Tag.ExportBundleCommand,
                                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          Visibility="{Binding PlacementTarget.DataContext.IsG1m,
                                                                       RelativeSource={RelativeSource AncestorType=ContextMenu},
                                                                       Converter={StaticResource BoolToVis}}"/>
                                                <!-- Non-G1M item -->
                                                <MenuItem Header="Raw Export"
                                                          Command="{Binding PlacementTarget.Tag.ExportSelectedCommand,
                                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          Visibility="{Binding PlacementTarget.DataContext.IsG1m,
                                                                       RelativeSource={RelativeSource AncestorType=ContextMenu},
                                                                       Converter={StaticResource InvertBoolToVis}}"/>
                                            </ContextMenu>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#c0392b"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="90" Padding="4,6" CornerRadius="4">
                                        <StackPanel HorizontalAlignment="Center">
                                            <Border Width="48" Height="48" CornerRadius="6"
                                                    Background="#2A2A2A"
                                                    HorizontalAlignment="Center" Margin="0,0,0,4">
                                                <TextBlock Text="{Binding TypeExt}"
                                                           FontSize="9" Opacity="0.6"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="10" TextWrapping="Wrap"
                                                       TextAlignment="Center"
                                                       MaxWidth="86" MaxHeight="32"
                                                       TextTrimming="CharacterEllipsis"
                                                       Opacity="0.85"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>

        <!-- Initialization overlay — blocks UI during first-time DOK scanning (cache miss) -->
        <Grid Grid.Row="0" Grid.RowSpan="4"
              Panel.ZIndex="10"
              Visibility="{Binding IsInitializing, Converter={StaticResource BoolToVis}}">
            <Rectangle Fill="#B4121212"/>
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="#1E1E1E" CornerRadius="8" Padding="32,24"
                    BorderBrush="#404040" BorderThickness="1"
                    MinWidth="400">
                <StackPanel>
                    <TextBlock Text="Analyzing Database"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="#E8E8E8" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="12" Foreground="#909090"
                               Margin="0,0,0,16" TextWrapping="Wrap" MaxWidth="380"/>
                    <ProgressBar Value="{Binding LoadProgress}" Maximum="100"
                                 Height="6" Width="340" HorizontalAlignment="Left"
                                 Margin="0,0,0,12"/>
                    <TextBlock Text="Only required on first load. Subsequent starts load from cache instantly."
                               FontSize="10" Foreground="#555555"
                               TextWrapping="Wrap" MaxWidth="340"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Row 2: Console resizer splitter -->
        <GridSplitter Grid.Row="2"
                      Height="5" HorizontalAlignment="Stretch"
                      ResizeDirection="Rows"
                      Background="{DynamicResource {x:Static adonisUI:Brushes.Layer1BorderBrush}}"
                      Cursor="SizeNS"/>

        <!-- Row 3: Console panel -->
        <Grid Grid.Row="3"
              Background="{DynamicResource {x:Static adonisUI:Brushes.Layer0BackgroundBrush}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="26"/>  <!-- header (always visible) -->
                <RowDefinition Height="*"/>   <!-- log content -->
            </Grid.RowDefinitions>

            <!-- Console header -->
            <Border Grid.Row="0"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{DynamicResource {x:Static adonisUI:Brushes.Layer1BorderBrush}}"
                    Padding="8,0">
                <DockPanel>
                    <Button DockPanel.Dock="Right"
                            x:Name="ConsoleToggleBtn"
                            Content="▾"
                            Click="ConsoleToggle_Click"
                            Padding="6,0" MinHeight="0" MinWidth="0" Height="22"
                            FontSize="11"
                            Background="Transparent" BorderThickness="0"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource {x:Static adonisUI:Brushes.DisabledForegroundBrush}}"
                            ToolTip="Toggle console"/>
                    <TextBlock Text="CONSOLE"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource {x:Static adonisUI:Brushes.DisabledForegroundBrush}}"
                               VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- Log text — bare TextBox with no AdonisUI hover/focus effects -->
            <TextBox Grid.Row="1"
                     x:Name="ConsoleTextBox"
                     IsReadOnly="True"
                     TextWrapping="NoWrap"
                     FontFamily="Consolas" FontSize="11"
                     Foreground="#AAAAAA"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="8,4"
                     AcceptsReturn="True"
                     FocusVisualStyle="{x:Null}"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TextBox">
                                    <ScrollViewer x:Name="PART_ContentHost"
                                                  Focusable="False"
                                                  Padding="{TemplateBinding Padding}"
                                                  VerticalScrollBarVisibility="{TemplateBinding VerticalScrollBarVisibility}"
                                                  HorizontalScrollBarVisibility="{TemplateBinding HorizontalScrollBarVisibility}"/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TextBox.Style>
            </TextBox>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="4"
                Background="{DynamicResource {x:Static adonisUI:Brushes.Layer2BackgroundBrush}}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource {x:Static adonisUI:Brushes.Layer1BorderBrush}}"
                Padding="8,3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="160"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusText}"
                           FontSize="11" VerticalAlignment="Center"
                           Foreground="{DynamicResource {x:Static adonisUI:Brushes.ForegroundBrush}}"/>
                <ProgressBar Grid.Column="1"
                             Value="{Binding LoadProgress}" Maximum="100" Height="5"
                             VerticalAlignment="Center" Margin="0,0,4,0"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
