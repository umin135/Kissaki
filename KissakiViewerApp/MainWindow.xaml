<Window x:Class="KissakiViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:adonisUI="clr-namespace:AdonisUI;assembly=AdonisUI"
        xmlns:conv="clr-namespace:KissakiViewer.Converters"
        Title="{Binding WindowTitle}"
        Width="1280" Height="800"
        MinWidth="900" MinHeight="500"
        Style="{DynamicResource {x:Type Window}}"
        Loaded="Window_Loaded">

    <Window.Resources>
        <BooleanToVisibilityConverter           x:Key="BoolToVis"/>
        <conv:InvertBoolConverter               x:Key="InvertBool"/>
        <conv:InvertBoolToVisibilityConverter   x:Key="InvertBoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menu bar -->
        <Menu Grid.Row="0"
              Background="{DynamicResource {x:Static adonisUI:Brushes.Layer1BackgroundBrush}}"
              BorderThickness="0,0,0,1"
              BorderBrush="{DynamicResource {x:Static adonisUI:Brushes.Layer1BorderBrush}}"
              Padding="4,2">
            <MenuItem Header="View">
                <MenuItem Header="Recover File Names"
                          Command="{Binding RecoverNamesCommand}"/>
            </MenuItem>
            <MenuItem Header="Settings"/>
            <MenuItem Header="Help"/>
        </Menu>

        <!-- Main content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="140"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: folder tree -->
            <Grid Grid.Column="0"
                  Background="{DynamicResource {x:Static adonisUI:Brushes.Layer1BackgroundBrush}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="8,5"
                        BorderThickness="0,0,0,1"
                        BorderBrush="{DynamicResource {x:Static adonisUI:Brushes.Layer1BorderBrush}}">
                    <TextBlock Text="Directory"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource {x:Static adonisUI:Brushes.DisabledForegroundBrush}}"/>
                </Border>

                <TreeView Grid.Row="1"
                          x:Name="FolderTreeView"
                          ItemsSource="{Binding FolderTree}"
                          BorderThickness="0"
                          Background="Transparent"
                          SelectedItemChanged="FolderTreeView_SelectedItemChanged">
                    <TreeView.Resources>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="True"/>
                            <Setter Property="Padding" Value="2,3"/>
                            <Setter Property="Foreground" Value="#DCDCDC"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource {x:Static adonisUI:Brushes.AccentBrush}}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1F1F1F"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TreeView.Resources>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding DisplayName}" FontSize="12" Padding="2,1"/>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Grid>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="{DynamicResource {x:Static adonisUI:Brushes.Layer1BorderBrush}}"/>

            <!-- Right: file browser -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Browser toolbar -->
                <Border Grid.Row="0"
                        Background="{DynamicResource {x:Static adonisUI:Brushes.Layer1BackgroundBrush}}"
                        BorderThickness="0,0,0,1"
                        BorderBrush="{DynamicResource {x:Static adonisUI:Brushes.Layer1BorderBrush}}"
                        Padding="8,5">
                    <DockPanel LastChildFill="False">
                        <TextBox DockPanel.Dock="Left"
                                 Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                                 MinWidth="200" MaxWidth="320"
                                 VerticalAlignment="Center"
                                 Tag="Search by name..."/>

                        <ComboBox DockPanel.Dock="Left"
                                  ItemsSource="{Binding TypeFilters}"
                                  SelectedItem="{Binding SelectedTypeFilter}"
                                  Width="90" Margin="6,0"/>

                        <ToggleButton DockPanel.Dock="Right"
                                      IsChecked="{Binding IsGridView}"
                                      ToolTip="Grid View"
                                      Padding="6,3">
                            <TextBlock Text="⊞" FontSize="13"/>
                        </ToggleButton>
                        <ToggleButton DockPanel.Dock="Right"
                                      IsChecked="{Binding IsGridView, Converter={StaticResource InvertBool}}"
                                      ToolTip="List View"
                                      Padding="6,3" Margin="0,0,2,0">
                            <TextBlock Text="≡" FontSize="14"/>
                        </ToggleButton>
                    </DockPanel>
                </Border>

                <!-- Asset area -->
                <Grid Grid.Row="1">

                    <!-- List view -->
                    <ListView x:Name="AssetListView"
                              ItemsSource="{Binding FilteredAssets}"
                              SelectedItem="{Binding SelectedAsset}"
                              BorderThickness="0"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              MouseDoubleClick="AssetList_MouseDoubleClick"
                              Visibility="{Binding IsGridView, Converter={StaticResource InvertBoolToVis}}">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="6,3"/>
                                <Setter Property="MinHeight" Value="26"/>
                                <Setter Property="Foreground" Value="#DCDCDC"/>
                                <!-- Tag = MainViewModel proxy so ContextMenu can reach commands -->
                                <Setter Property="Tag"
                                        Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListView}}"/>
                                <Setter Property="ContextMenu">
                                    <Setter.Value>
                                        <ContextMenu>
                                            <!-- PlacementTarget = ListViewItem; .Tag = MainViewModel; .DataContext = AssetItemViewModel -->
                                            <MenuItem Header="Save Model (FBX)"
                                                      Command="{Binding PlacementTarget.Tag.SaveModelCommand,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext,
                                                                         RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <MenuItem Header="Export Raw"
                                                      Command="{Binding PlacementTarget.Tag.ExportSelectedCommand,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        </ContextMenu>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1F1F1F"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource {x:Static adonisUI:Brushes.AccentBrush}}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Name" Width="300">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayFileName}"
                                                       FontFamily="Consolas" FontSize="12"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Type" Width="60">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding TypeExt}" FontSize="11" Opacity="0.65"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Size" Width="80">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding SizeStr}" FontSize="11" Opacity="0.55"
                                                       HorizontalAlignment="Right"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Hash" Width="110">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding KtidHex}"
                                                       FontFamily="Consolas" FontSize="11" Opacity="0.5"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <!-- Grid view -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Visibility="{Binding IsGridView, Converter={StaticResource BoolToVis}}">
                        <ListBox ItemsSource="{Binding FilteredAssets}"
                                 SelectedItem="{Binding SelectedAsset}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                 MouseDoubleClick="AssetList_MouseDoubleClick">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" Margin="4"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="3"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="Tag"
                                            Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                                    <Setter Property="ContextMenu">
                                        <Setter.Value>
                                            <ContextMenu>
                                                <MenuItem Header="Save Model (FBX)"
                                                          Command="{Binding PlacementTarget.Tag.SaveModelCommand,
                                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext,
                                                                             RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                <MenuItem Header="Export Raw"
                                                          Command="{Binding PlacementTarget.Tag.ExportSelectedCommand,
                                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            </ContextMenu>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource {x:Static adonisUI:Brushes.AccentBrush}}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="90" Padding="4,6" CornerRadius="4">
                                        <StackPanel HorizontalAlignment="Center">
                                            <Border Width="48" Height="48" CornerRadius="6"
                                                    Background="#2A2A2A"
                                                    HorizontalAlignment="Center" Margin="0,0,0,4">
                                                <TextBlock Text="{Binding TypeExt}"
                                                           FontSize="9" Opacity="0.6"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="{Binding DisplayFileName}"
                                                       FontSize="10" TextWrapping="Wrap"
                                                       TextAlignment="Center"
                                                       MaxWidth="86" MaxHeight="32"
                                                       TextTrimming="CharacterEllipsis"
                                                       Opacity="0.85"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource {x:Static adonisUI:Brushes.Layer2BackgroundBrush}}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource {x:Static adonisUI:Brushes.Layer1BorderBrush}}"
                Padding="8,3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="160"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusText}"
                           FontSize="11" VerticalAlignment="Center"
                           Foreground="{DynamicResource {x:Static adonisUI:Brushes.ForegroundBrush}}"/>
                <ProgressBar Grid.Column="1"
                             Value="{Binding LoadProgress}" Maximum="100" Height="5"
                             VerticalAlignment="Center" Margin="0,0,4,0"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
