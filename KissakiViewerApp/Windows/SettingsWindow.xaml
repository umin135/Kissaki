<Window x:Class="KissakiViewer.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:adonisUI="clr-namespace:AdonisUI;assembly=AdonisUI"
        Title="Settings"
        Icon="/Assets/app.ico"
        Width="580" Height="340"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Style="{DynamicResource {x:Type Window}}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: category list -->
        <Border Grid.Row="0" Grid.Column="0"
                Background="{DynamicResource {x:Static adonisUI:Brushes.Layer0BackgroundBrush}}"
                BorderThickness="0,0,1,0"
                BorderBrush="{DynamicResource {x:Static adonisUI:Brushes.Layer1BorderBrush}}">
            <ListBox x:Name="CategoryList"
                     BorderThickness="0"
                     Background="Transparent"
                     SelectedIndex="0">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground"
                                Value="{DynamicResource {x:Static adonisUI:Brushes.ForegroundBrush}}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#c0392b"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1F1F1F"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBoxItem Content="General" Padding="14,9" FontSize="13"/>
            </ListBox>
        </Border>

        <!-- Right: settings panel -->
        <ScrollViewer Grid.Row="0" Grid.Column="1"
                      Padding="20,18"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Export Directory row -->
                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Export Directory"
                               VerticalAlignment="Center"
                               FontSize="12"/>
                    <TextBox Grid.Column="1"
                             x:Name="ExportDirBox"
                             VerticalAlignment="Center"
                             FontFamily="Consolas"
                             FontSize="11"
                             Margin="8,0"
                             ToolTip="Leave empty to use the default: &lt;exe dir&gt;/export"/>
                    <Button Grid.Column="2"
                            Content="..."
                            Width="28" Height="24"
                            VerticalAlignment="Center"
                            Click="BrowseExportDir_Click"/>
                </Grid>

                <!-- Delete DB Cache row -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Database Cache"
                               VerticalAlignment="Center"
                               FontSize="12"/>
                    <Button Grid.Column="1"
                            HorizontalAlignment="Left"
                            Content="Delete DB Cache"
                            Padding="10,4"
                            Margin="8,0"
                            Click="DeleteCache_Click"/>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- Bottom bar -->
        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource {x:Static adonisUI:Brushes.Layer1BorderBrush}}"
                Padding="12,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Reset to Default"
                        Padding="12,5" Margin="0,0,8,0"
                        Click="ResetDefault_Click"/>
                <Button Content="Save"
                        Padding="22,5"
                        Click="Save_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
