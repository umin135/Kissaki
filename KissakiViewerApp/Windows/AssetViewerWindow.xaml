<Window x:Class="KissakiViewer.Windows.AssetViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:adonisUI="clr-namespace:AdonisUI;assembly=AdonisUI"
        xmlns:helix="http://helix-toolkit.org/wpf"
        xmlns:conv="clr-namespace:KissakiViewer.Converters"
        xmlns:vm="clr-namespace:KissakiViewer.ViewModels"
        Title="Kissaki — Asset Viewer"
        Width="1000" Height="700"
        MinWidth="600" MinHeight="400"
        Style="{DynamicResource {x:Type Window}}">

    <Window.Resources>
        <BooleanToVisibilityConverter         x:Key="BoolToVis"/>
        <conv:InvertBoolToVisibilityConverter x:Key="InvertBoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Tab strip -->
            <RowDefinition Height="*"/>     <!-- Content -->
            <RowDefinition Height="Auto"/>  <!-- Info bar -->
        </Grid.RowDefinitions>

        <!-- Tab strip (custom, since we need close buttons) -->
        <Border Grid.Row="0"
                Background="{DynamicResource {x:Static adonisUI:Brushes.Layer1BackgroundBrush}}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource {x:Static adonisUI:Brushes.Layer1BorderBrush}}">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Tabs}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:AssetTabItem}">
                            <Border x:Name="TabBorder"
                                    MinWidth="120" MaxWidth="220"
                                    Padding="10,6,4,6"
                                    BorderThickness="0,0,1,0"
                                    BorderBrush="{DynamicResource {x:Static adonisUI:Brushes.Layer1BorderBrush}}"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="TabHeader_MouseLeftButtonDown">
                                <DockPanel>
                                    <Button DockPanel.Dock="Right"
                                            Content="✕"
                                            FontSize="9"
                                            Width="16" Height="16"
                                            Padding="0" Margin="4,0,0,0"
                                            VerticalAlignment="Center"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"/>
                                    <TextBlock Text="{Binding Header}"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource {x:Static adonisUI:Brushes.ForegroundBrush}}"/>
                                </DockPanel>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Background"
                                                        Value="{DynamicResource {x:Static adonisUI:Brushes.AccentBrush}}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Content area -->
        <Grid Grid.Row="1"
              Background="{DynamicResource {x:Static adonisUI:Brushes.Layer0BackgroundBrush}}">

            <!-- No tabs placeholder -->
            <TextBlock Text="에셋을 더블 클릭하면 이곳에 열립니다."
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="13"
                       Foreground="{DynamicResource {x:Static adonisUI:Brushes.DisabledForegroundBrush}}"
                       Visibility="{Binding HasTabs, Converter={StaticResource InvertBoolToVis}}"/>

            <!-- Loading indicator -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding SelectedTab.IsLoading, Converter={StaticResource BoolToVis},
                                             FallbackValue=Collapsed}">
                <TextBlock Text="로딩 중..." FontSize="14"
                           Foreground="{DynamicResource {x:Static adonisUI:Brushes.DisabledForegroundBrush}}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Texture preview -->
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding SelectedTab.PreviewImage, Converter={x:Static conv:NullToVisibilityConverter.Instance},
                                               FallbackValue=Collapsed}">
                <Image Source="{Binding SelectedTab.PreviewImage}"
                       Stretch="Uniform" Margin="8"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
            </ScrollViewer>

            <!-- 3D model viewport (always present, visibility toggled) -->
            <helix:HelixViewport3D x:Name="Viewport3D"
                                   Background="#111111"
                                   ShowCoordinateSystem="False"
                                   ShowViewCube="True"
                                   ZoomExtentsWhenLoaded="False"
                                   Visibility="{Binding SelectedTab.HasModelPreview, Converter={StaticResource BoolToVis},
                                                        FallbackValue=Collapsed}">
                <helix:DefaultLights/>
                <ModelVisual3D x:Name="SceneRoot"/>
            </helix:HelixViewport3D>
        </Grid>

        <!-- Info / slot bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource {x:Static adonisUI:Brushes.Layer1BackgroundBrush}}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource {x:Static adonisUI:Brushes.Layer1BorderBrush}}"
                Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Slot slider (shown for multi-slot textures) -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            Visibility="{Binding SelectedTab.HasMultipleSlots, Converter={StaticResource BoolToVis},
                                                 FallbackValue=Collapsed}"
                            Margin="0,0,12,0">
                    <TextBlock Text="Slot" FontSize="11" VerticalAlignment="Center"
                               Foreground="#DCDCDC" Margin="0,0,8,0"/>
                    <Slider Value="{Binding SelectedTab.CurrentSlotIndex}"
                            Minimum="0"
                            Maximum="{Binding SelectedTab.SlotMax, Mode=OneWay}"
                            Width="160" IsSnapToTickEnabled="True" TickFrequency="1"
                            VerticalAlignment="Center"/>
                    <TextBlock FontFamily="Consolas" FontSize="11"
                               VerticalAlignment="Center" Margin="6,0,0,0"
                               Foreground="#DCDCDC">
                        <Run Text="{Binding SelectedTab.CurrentSlotIndex, Mode=OneWay}"/>
                        <Run Text=" / "/>
                        <Run Text="{Binding SelectedTab.SlotMax, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding SelectedTab.PreviewInfo}"
                           FontFamily="Consolas" FontSize="11"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource {x:Static adonisUI:Brushes.DisabledForegroundBrush}}"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>
    </Grid>
</Window>
