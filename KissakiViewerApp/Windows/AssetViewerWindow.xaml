<Window x:Class="KissakiViewer.Windows.AssetViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:adonisUI="clr-namespace:AdonisUI;assembly=AdonisUI"
        xmlns:helix="http://helix-toolkit.org/wpf"
        xmlns:conv="clr-namespace:KissakiViewer.Converters"
        xmlns:vm="clr-namespace:KissakiViewer.ViewModels"
        Title="Kissaki — Asset Viewer"
        Width="1200" Height="700"
        MinWidth="600" MinHeight="400"
        Style="{DynamicResource {x:Type Window}}">

    <Window.Resources>
        <BooleanToVisibilityConverter         x:Key="BoolToVis"/>
        <conv:InvertBoolToVisibilityConverter x:Key="InvertBoolToVis"/>

        <!-- Plain TextBox template: no AdonisUI hover/focus effects -->
        <ControlTemplate x:Key="JsonViewerTemplate" TargetType="TextBox">
            <Border Background="#1a1a1a" SnapsToDevicePixels="True">
                <ScrollViewer x:Name="PART_ContentHost"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              Padding="12"/>
            </Border>
        </ControlTemplate>

        <!-- ListBox item style for detail panel -->
        <Style x:Key="DetailListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#33009FFF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1A009FFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Tab strip -->
            <RowDefinition Height="*"/>     <!-- Content -->
            <RowDefinition Height="Auto"/>  <!-- Info bar -->
        </Grid.RowDefinitions>

        <!-- Tab strip -->
        <Border Grid.Row="0"
                Background="{DynamicResource {x:Static adonisUI:Brushes.Layer1BackgroundBrush}}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource {x:Static adonisUI:Brushes.Layer1BorderBrush}}">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Tabs}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:AssetTabItem}">
                            <Border x:Name="TabBorder"
                                    MinWidth="120" MaxWidth="220"
                                    Padding="10,6,4,6"
                                    BorderThickness="0,0,1,0"
                                    BorderBrush="{DynamicResource {x:Static adonisUI:Brushes.Layer1BorderBrush}}"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="TabHeader_MouseLeftButtonDown">
                                <DockPanel>
                                    <Button DockPanel.Dock="Right"
                                            Content="✕"
                                            FontSize="9"
                                            Width="16" Height="16"
                                            Padding="0" Margin="4,0,0,0"
                                            VerticalAlignment="Center"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"/>
                                    <TextBlock Text="{Binding Header}"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource {x:Static adonisUI:Brushes.ForegroundBrush}}"/>
                                </DockPanel>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Background"
                                                        Value="{DynamicResource {x:Static adonisUI:Brushes.AccentBrush}}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Content area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Left detail panel: Width=Auto → collapses to 0 when content is Collapsed -->
                <ColumnDefinition Width="Auto"/>
                <!-- Drag handle -->
                <ColumnDefinition Width="Auto"/>
                <!-- Main viewport / preview -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Left: G1M detail panel (model mode only) ───────────────── -->
            <Border Grid.Column="0"
                    x:Name="DetailPanel"
                    Width="220"
                    Background="{DynamicResource {x:Static adonisUI:Brushes.Layer1BackgroundBrush}}"
                    BorderBrush="{DynamicResource {x:Static adonisUI:Brushes.Layer1BorderBrush}}"
                    BorderThickness="0,0,1,0"
                    Visibility="{Binding SelectedTab.IsModelMode, FallbackValue=False,
                                         Converter={StaticResource BoolToVis}}">
                <DockPanel>
                    <!-- "Detail" header -->
                    <Border DockPanel.Dock="Top"
                            Padding="10,7"
                            BorderBrush="{DynamicResource {x:Static adonisUI:Brushes.Layer1BorderBrush}}"
                            BorderThickness="0,0,0,1">
                        <TextBlock Text="Detail"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource {x:Static adonisUI:Brushes.ForegroundBrush}}"/>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>

                            <!-- Sub-Meshes section -->
                            <Expander Header="Sub-Meshes" IsExpanded="True" Margin="0,4,0,0">
                                <ListBox x:Name="SubmeshListBox"
                                         ItemsSource="{Binding SelectedTab.SubmeshItems}"
                                         SelectionMode="Single"
                                         SelectionChanged="OnSubmeshSelectionChanged"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ItemContainerStyle="{StaticResource DetailListItemStyle}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:SubmeshItemVM}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Name}"
                                                           FontFamily="Consolas" FontSize="11"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource {x:Static adonisUI:Brushes.ForegroundBrush}}"/>
                                                <!-- Eye toggle: ◎ = visible, ⊗ = hidden -->
                                                <ToggleButton Grid.Column="1"
                                                              IsChecked="{Binding IsVisible, Mode=TwoWay}"
                                                              Width="22" Height="18"
                                                              Padding="0" Margin="4,0,0,0"
                                                              FontSize="12"
                                                              Background="Transparent"
                                                              BorderThickness="0"
                                                              ToolTip="Toggle visibility">
                                                    <ToggleButton.Style>
                                                        <Style TargetType="ToggleButton">
                                                            <Setter Property="Content" Value="◎"/>
                                                            <Setter Property="Foreground" Value="#70C070"/>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsChecked" Value="False">
                                                                    <Setter Property="Content" Value="⊗"/>
                                                                    <Setter Property="Foreground" Value="#505050"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ToggleButton.Style>
                                                </ToggleButton>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Expander>

                            <!-- Material Slots section -->
                            <Expander Header="MaterialSlots" IsExpanded="True" Margin="0,4,0,0">
                                <ListBox x:Name="MaterialListBox"
                                         ItemsSource="{Binding SelectedTab.MaterialItems}"
                                         SelectionMode="Single"
                                         SelectionChanged="OnMaterialSelectionChanged"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ItemContainerStyle="{StaticResource DetailListItemStyle}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:MaterialSlotItemVM}">
                                            <TextBlock Text="{Binding Name}"
                                                       FontFamily="Consolas" FontSize="11"
                                                       Foreground="{DynamicResource {x:Static adonisUI:Brushes.ForegroundBrush}}"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Expander>

                            <!-- UV Map section -->
                            <Expander Header="UV Map" IsExpanded="True" Margin="0,4,0,4">
                                <Border Margin="4,2,4,2"
                                        BorderThickness="1"
                                        BorderBrush="{DynamicResource {x:Static adonisUI:Brushes.Layer1BorderBrush}}">
                                    <Grid Width="202" Height="202" ClipToBounds="True" Background="#0D0D0D">
                                        <Image x:Name="UvMapImage" Stretch="Fill" Opacity="0.55"
                                               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                        <Canvas x:Name="UvMapCanvas" Width="202" Height="202" Background="Transparent"/>
                                    </Grid>
                                </Border>
                            </Expander>

                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- GridSplitter (only when model mode) -->
            <GridSplitter Grid.Column="1"
                          Width="5"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns"
                          VerticalAlignment="Stretch"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource {x:Static adonisUI:Brushes.Layer1BorderBrush}}"
                          Visibility="{Binding SelectedTab.IsModelMode, FallbackValue=False,
                                               Converter={StaticResource BoolToVis}}"/>

            <!-- ── Main content (Column=2) ────────────────────────────────── -->
            <Grid Grid.Column="2"
                  Background="{DynamicResource {x:Static adonisUI:Brushes.Layer0BackgroundBrush}}">

                <!-- No tabs placeholder -->
                <TextBlock Text="에셋을 더블 클릭하면 이곳에 열립니다."
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="13"
                           Foreground="{DynamicResource {x:Static adonisUI:Brushes.DisabledForegroundBrush}}"
                           Visibility="{Binding HasTabs, Converter={StaticResource InvertBoolToVis}}"/>

                <!-- Loading indicator -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding SelectedTab.IsLoading, Converter={StaticResource BoolToVis},
                                                 FallbackValue=Collapsed}">
                    <TextBlock Text="로딩 중..." FontSize="14"
                               Foreground="{DynamicResource {x:Static adonisUI:Brushes.DisabledForegroundBrush}}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Texture preview (PreviewMode.Texture) -->
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTab.PreviewMode}"
                                             Value="{x:Static vm:PreviewMode.Texture}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <Image Source="{Binding SelectedTab.PreviewImage}"
                           Stretch="Uniform" Margin="8"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </ScrollViewer>

                <!-- JSON / text preview (PreviewMode.Json) -->
                <TextBox Text="{Binding SelectedTab.JsonText, Mode=OneWay}"
                         IsReadOnly="True"
                         IsReadOnlyCaretVisible="True"
                         FontFamily="Consolas"
                         FontSize="12"
                         Foreground="#dcdcdc"
                         CaretBrush="#dcdcdc"
                         SelectionBrush="#c0392b"
                         TextWrapping="NoWrap"
                         AcceptsReturn="True"
                         Template="{StaticResource JsonViewerTemplate}">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTab.PreviewMode}"
                                             Value="{x:Static vm:PreviewMode.Json}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- 3D model viewport (PreviewMode.Model) -->
                <helix:HelixViewport3D x:Name="Viewport3D"
                                       Background="#111111"
                                       ShowCoordinateSystem="False"
                                       ShowViewCube="False"
                                       ZoomExtentsWhenLoaded="False">
                    <helix:HelixViewport3D.Style>
                        <Style TargetType="helix:HelixViewport3D">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTab.PreviewMode}"
                                             Value="{x:Static vm:PreviewMode.Model}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </helix:HelixViewport3D.Style>
                    <helix:DefaultLights/>
                    <ModelVisual3D x:Name="SkyboxRoot"/>
                    <helix:GridLinesVisual3D x:Name="GridViz"
                                             Width="400" Length="400"
                                             Thickness="0.5"
                                             MinorDistance="10"
                                             MajorDistance="50"
                                             Fill="#FF606060"/>
                    <ModelVisual3D x:Name="AxesRoot"/>
                    <ModelVisual3D x:Name="BoneRoot"/>
                    <ModelVisual3D x:Name="SceneRoot"/>
                </helix:HelixViewport3D>

                <!-- Axis gizmo overlay (bottom-right) -->
                <Canvas x:Name="GizmoCanvas"
                        Width="90" Height="90"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                        Margin="0,0,12,12"
                        Panel.ZIndex="99">
                    <Canvas.Style>
                        <Style TargetType="Canvas">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTab.PreviewMode}"
                                             Value="{x:Static vm:PreviewMode.Model}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Canvas.Style>
                </Canvas>

                <!-- Bone X-ray toggle (top-right, model mode only) -->
                <ToggleButton IsChecked="{Binding SelectedTab.ShowBones, FallbackValue=False}"
                              HorizontalAlignment="Right" VerticalAlignment="Top"
                              Margin="0,8,8,0" Padding="8,4"
                              FontSize="11"
                              Panel.ZIndex="100"
                              ToolTip="Toggle bone overlay">
                    <ToggleButton.Style>
                        <Style TargetType="ToggleButton">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Setter Property="Content" Value="Bones"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTab.PreviewMode}"
                                             Value="{x:Static vm:PreviewMode.Model}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Content" Value="Bones ●"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ToggleButton.Style>
                </ToggleButton>

            </Grid><!-- /Main content -->

        </Grid><!-- /Content area -->

        <!-- Info / slot bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource {x:Static adonisUI:Brushes.Layer1BackgroundBrush}}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource {x:Static adonisUI:Brushes.Layer1BorderBrush}}"
                Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Slot slider (shown for multi-slot textures) -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            Visibility="{Binding SelectedTab.HasMultipleSlots, Converter={StaticResource BoolToVis},
                                                 FallbackValue=Collapsed}"
                            Margin="0,0,12,0">
                    <TextBlock Text="Slot" FontSize="11" VerticalAlignment="Center"
                               Foreground="#DCDCDC" Margin="0,0,8,0"/>
                    <Slider Value="{Binding SelectedTab.CurrentSlotIndex}"
                            Minimum="0"
                            Maximum="{Binding SelectedTab.SlotMax, Mode=OneWay}"
                            Width="160" IsSnapToTickEnabled="True" TickFrequency="1"
                            VerticalAlignment="Center"/>
                    <TextBlock FontFamily="Consolas" FontSize="11"
                               VerticalAlignment="Center" Margin="6,0,0,0"
                               Foreground="#DCDCDC">
                        <Run Text="{Binding SelectedTab.CurrentSlotIndex, Mode=OneWay}"/>
                        <Run Text=" / "/>
                        <Run Text="{Binding SelectedTab.SlotMax, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding SelectedTab.PreviewInfo}"
                           FontFamily="Consolas" FontSize="11"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource {x:Static adonisUI:Brushes.DisabledForegroundBrush}}"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>
    </Grid>
</Window>
