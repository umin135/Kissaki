<Window x:Class="KissakiViewer.Windows.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:adonisUI="clr-namespace:AdonisUI;assembly=AdonisUI"
        Title="Help"
        Icon="/Assets/app.ico"
        Width="420" Height="290"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Style="{DynamicResource {x:Type Window}}">

    <StackPanel Margin="28,22">

        <!-- Header: logo + title/subtitle -->
        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Logo -->
            <Image Grid.Column="0" Source="/Assets/logo.png"
                   Width="64" Height="64" Stretch="Uniform"
                   Margin="0,0,18,0" VerticalAlignment="Center"/>

            <!-- Title + version + subtitle -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="Kissaki"
                               FontSize="22" FontWeight="Bold"
                               Foreground="#c0392b"
                               VerticalAlignment="Bottom"
                               Margin="0,0,8,0"/>
                    <TextBlock x:Name="VersionText"
                               FontSize="11" Opacity="0.55"
                               VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                </StackPanel>
                <TextBlock Text="Katana Engine Universal Asset Viewer"
                           FontSize="11" Opacity="0.5"/>
            </StackPanel>
        </Grid>

        <Separator Margin="0,0,0,14"
                   BorderBrush="{DynamicResource {x:Static adonisUI:Brushes.Layer1BorderBrush}}"/>

        <!-- Developer -->
        <TextBlock FontSize="12" Margin="0,0,0,7">
            <Run Text="Developer: " Foreground="#888888"/>
            <Run Text="UMIN" FontWeight="SemiBold"/>
        </TextBlock>

        <!-- Contact -->
        <TextBlock FontSize="11" Opacity="0.65" TextWrapping="Wrap" Margin="0,0,0,16"
                   Text="If you have trouble using this tool or want to report an issue, reach us on Discord."/>

        <Separator Margin="0,0,0,14"
                   BorderBrush="{DynamicResource {x:Static adonisUI:Brushes.Layer1BorderBrush}}"/>

        <!-- Links -->
        <StackPanel Orientation="Horizontal">
            <TextBlock FontSize="12" Margin="0,0,22,0">
                <Hyperlink NavigateUri="https://github.com/umin135/Kissaki"
                           RequestNavigate="Hyperlink_RequestNavigate"
                           Foreground="#c0392b" TextDecorations="None"
                           FontWeight="Bold">
                    GitHub
                </Hyperlink>
            </TextBlock>
            <TextBlock FontSize="12">
                <Hyperlink NavigateUri="https://discord.gg/jwaB8zhb9v"
                           RequestNavigate="Hyperlink_RequestNavigate"
                           Foreground="#c0392b" TextDecorations="None"
                           FontWeight="Bold">
                    Discord
                </Hyperlink>
            </TextBlock>
        </StackPanel>

    </StackPanel>
</Window>
