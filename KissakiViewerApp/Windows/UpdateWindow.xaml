<Window x:Class="KissakiViewer.Windows.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:adonisUI="clr-namespace:AdonisUI;assembly=AdonisUI"
        Title="Update Available"
        Icon="/Assets/app.ico"
        Width="480" Height="400"
        MinHeight="320"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        Style="{DynamicResource {x:Type Window}}">

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="A new version is available!"
                       FontSize="16" FontWeight="SemiBold"/>
            <TextBlock x:Name="VersionLabel"
                       FontSize="11" Opacity="0.55" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Top separator -->
        <Separator Grid.Row="1" Margin="0,12,0,0"
                   BorderBrush="{DynamicResource {x:Static adonisUI:Brushes.Layer1BorderBrush}}"/>

        <!-- Changelog -->
        <ScrollViewer Grid.Row="2" Margin="0,10" VerticalScrollBarVisibility="Auto">
            <TextBlock x:Name="ChangelogText"
                       FontSize="12" TextWrapping="Wrap"
                       Opacity="0.85" FontFamily="Consolas"/>
        </ScrollViewer>

        <!-- Bottom separator -->
        <Separator Grid.Row="3" Margin="0,0,0,10"
                   BorderBrush="{DynamicResource {x:Static adonisUI:Brushes.Layer1BorderBrush}}"/>

        <!-- Download progress (hidden until Update is clicked) -->
        <StackPanel Grid.Row="4" x:Name="ProgressPanel" Visibility="Collapsed" Margin="0,0,0,10">
            <TextBlock x:Name="StatusText" FontSize="11" Opacity="0.7" Margin="0,0,0,4"/>
            <ProgressBar x:Name="ProgressBar" Height="4" Minimum="0" Maximum="100" Value="0"/>
        </StackPanel>

        <!-- Buttons -->
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" x:Name="UpdateButton"
                    Content="Update" Width="90"
                    IsDefault="True" Click="Update_Click"/>
            <Button Grid.Column="3" x:Name="NotNowButton"
                    Content="Not Now" Width="90"
                    IsCancel="True" Click="NotNow_Click"/>
        </Grid>
    </Grid>

</Window>
